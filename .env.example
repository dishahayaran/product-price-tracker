# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# Gmail address used to send notifications
GMAIL_USER=yourname@gmail.com

# 16-character Gmail App Password (NOT your Gmail login password)
# How to get one: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
GMAIL_APP_PASS=abcd efgh ijkl mnop

# Email address to receive price alerts (can be the same as GMAIL_USER)
NOTIFY_EMAIL=yourname@gmail.com

# Set to "true" to see verbose debug logs when running locally
DEBUG=false
